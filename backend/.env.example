# Supabase project URL — Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon (public) key — Supabase Dashboard → Project Settings → API → anon / public
SUPABASE_ANON_KEY=<anon key here>

# Service role key (bypasses RLS — keep secret!) — Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=<service_role key here>

# JWT Secret — Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# This is a long base64 string used to verify Supabase access tokens
SUPABASE_JWT_SECRET=<JWT secret here>
